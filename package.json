{
  "name": "suitable-rms",
  "private": true,
  "version": "2.0.13",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite",
    "api:dev": "node server/index.js",
    "build": "npm run build:web",
    "build:web": "vite build",
    "start:web": "node scripts/start-web-preview.mjs",
    "build:desktop:web": "vite build --config vite.desktop.config.js",
    "desktop:start": "npm run build:desktop:web && electron .",
    "build:desktop": "npm run build:desktop:web && electron-builder --win nsis",
    "publish:desktop": "npm run build:desktop:web && electron-builder --win nsis -p always",
    "preview": "vite preview",
    "bootstrap:company-tree": "node scripts/bootstrap-company-tree.mjs",
    "bootstrap:company-tree:validate": "node scripts/bootstrap-company-tree.mjs --validate-only",
    "bootstrap:reference-data": "node scripts/bootstrap-reference-master-data.mjs",
    "bootstrap:reference-data:schema": "node scripts/bootstrap-reference-master-data.mjs --schema-only",
    "bootstrap:reference-data:seed": "node scripts/bootstrap-reference-master-data.mjs --seed-only",
    "bootstrap:templates": "node scripts/bootstrap-templates.mjs",
    "bootstrap:templates:schema": "node scripts/bootstrap-templates.mjs --schema-only",
    "bootstrap:templates:seed": "node scripts/bootstrap-templates.mjs --seed-only",
    "bootstrap:personnel-demo": "node scripts/bootstrap-personnel-demo.mjs",
    "bootstrap:personnel-demo:dry-run": "node scripts/bootstrap-personnel-demo.mjs --dry-run",
    "bootstrap:personnel-demo:verify": "node scripts/bootstrap-personnel-demo.mjs --verify-only",
    "bootstrap:contracts-demo": "node scripts/bootstrap-contracts-demo.mjs",
    "bootstrap:contracts-demo:dry-run": "node scripts/bootstrap-contracts-demo.mjs --dry-run",
    "bootstrap:contracts-demo:verify": "node scripts/bootstrap-contracts-demo.mjs --verify-only",
    "bootstrap:customers-demo": "node scripts/bootstrap-customers-demo.mjs",
    "bootstrap:customers-demo:dry-run": "node scripts/bootstrap-customers-demo.mjs --dry-run",
    "bootstrap:customers-demo:verify": "node scripts/bootstrap-customers-demo.mjs --verify-only",
    "bootstrap:address-reference-demo": "node scripts/bootstrap-address-reference-demo.mjs",
    "bootstrap:address-reference-demo:schema": "node scripts/bootstrap-address-reference-demo.mjs --schema-only",
    "bootstrap:address-reference-demo:seed": "node scripts/bootstrap-address-reference-demo.mjs --seed-only",
    "bootstrap:address-reference-demo:verify": "node scripts/bootstrap-address-reference-demo.mjs --verify-only",
    "bootstrap:branch-service-authority-demo": "node scripts/bootstrap-branch-service-authority-demo.mjs",
    "bootstrap:branch-service-authority-demo:schema": "node scripts/bootstrap-branch-service-authority-demo.mjs --schema-only",
    "bootstrap:branch-service-authority-demo:seed": "node scripts/bootstrap-branch-service-authority-demo.mjs --seed-only",
    "bootstrap:branch-service-authority-demo:verify": "node scripts/bootstrap-branch-service-authority-demo.mjs --verify-only",
    "bootstrap:catalog-hamburger-pilot": "node scripts/bootstrap-hamburger-pilot-catalog.mjs",
    "bootstrap:catalog-hamburger-pilot:schema": "node scripts/bootstrap-hamburger-pilot-catalog.mjs --schema-only",
    "bootstrap:catalog-hamburger-pilot:seed": "node scripts/bootstrap-hamburger-pilot-catalog.mjs --seed-only",
    "bootstrap:order-flow-demos": "node scripts/bootstrap-order-flow-demos.mjs",
    "bootstrap:sale-showcase-60": "node scripts/bootstrap-sale-showcase-60.mjs",
    "bootstrap:sale-showcase-60:audit": "node scripts/bootstrap-sale-showcase-60.mjs --audit-only",
    "bootstrap:sale-showcase-60:verify": "node scripts/bootstrap-sale-showcase-60.mjs --verify-only",
    "bootstrap:loyalty-redemption-smoke": "node scripts/bootstrap-loyalty-redemption-smoke.mjs",
    "bootstrap:loyalty-redemption-smoke:verify": "node scripts/bootstrap-loyalty-redemption-smoke.mjs --verify-only",
    "bootstrap:referrals-demo": "node scripts/bootstrap-referrals-demo.mjs",
    "run:loyalty-redemption-smoke": "node scripts/run-loyalty-redemption-smoke.mjs",
    "verify:loyalty-redemption-smoke": "node scripts/verify-loyalty-redemption-smoke.mjs",
    "enrich:sale-showcase-pricing": "node scripts/enrich-sale-showcase-pricing.mjs",
    "enrich:sale-showcase-pricing:audit": "node scripts/enrich-sale-showcase-pricing.mjs --audit-only",
    "enrich:sale-showcase-pricing:verify": "node scripts/enrich-sale-showcase-pricing.mjs --verify-only",
    "check:encoding": "node scripts/check-mojibake.mjs",
    "check:protected-docs": "node scripts/check-protected-docs.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "electron-updater": "^6.1.8",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^4.3.136",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.23.1",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "pg": "^8.16.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.12"
  },
  "build": {
    "appId": "com.suitable.rms.pos",
    "productName": "SuitableRMS POS",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "muzafferseyranli1",
      "repo": "RMSv3"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist-desktop-web/**/*",
      "desktop/**/*.cjs",
      "node_modules/better-sqlite3/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/ws/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    }
  }
}
